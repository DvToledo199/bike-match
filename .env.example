# Copy this file to .env (repo root) and adjust the values for your machine.
# .env is gitignored: never commit real credentials.

# --- PostgreSQL (used by docker-compose and by the backend) ---
POSTGRES_DB=bikematch
POSTGRES_USER=bikematch
POSTGRES_PASSWORD=bikematch

# --- Backend datasource (host/port where the backend finds PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432

# --- CORS (frontend dev origin allowed by the backend) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
